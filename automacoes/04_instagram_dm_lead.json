        "jsonOutput": "={\"recipient\": {\"id\": \"{{ $('Parsear DM do Instagram').first().json.ig_sender_id }}\"}, \"message\": {\"text\": \"Oi! 👋 Aqui é o sistema da HLJ DEV. Recebi sua mensagem e já avisamos a equipe. Em breve um especialista te responderá. Enquanto isso, você pode ver o que fazemos em: hljdev.com.br ⚡\"}}",
        "options": {}
      },
