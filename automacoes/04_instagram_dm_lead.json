      "id": "node-webhook-ig-verify",
      "name": "Webhook — Verificação Meta (GET)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 480],
      "webhookId": "hlj-instagram-dm",
      "notes": "A Meta faz uma requisição GET para verificar o webhook. Este nó responde com o hub.challenge."
    },
    {
      "parameters": {
        "jsCode": "// Responde ao desafio de verificação da Meta\nconst query = $input.first().json.query;\nif (query['hub.mode'] === 'subscribe' && query['hub.verify_token'] === $env.META_VERIFY_TOKEN) {\n  return [{ json: { challenge: query['hub.challenge'] } }];\n}\nreturn [{ json: { error: 'Token inválido' } }];"
      },
      "id": "node-meta-verify",
      "name": "Responder Verificação Meta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 480]
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// HLJ DEV — Instagram DM Parser v1.0\n// ============================================\n// Extrai a mensagem recebida via Instagram DM\n// usando o Meta Graph API Webhook\n// ============================================\n\nconst body = $input.first().json.body;\n\n// Estrutura do payload Meta Messenger/Instagram\nconst entry = body.entry?.[0];\nconst messaging = entry?.messaging?.[0];\n\nif (!messaging) {\n  return [{ json: { ignorar: true, motivo: 'Sem messaging event' } }];\n}\n\nconst remetenteId = messaging.sender?.id;\nconst texto = messaging.message?.text || '';\nconst timestamp = messaging.timestamp;\n\n// Ignora mensagens enviadas pelo próprio bot (echo)\nif (messaging.message?.is_echo) {\n  return [{ json: { ignorar: true, motivo: 'Echo da própria conta' } }];\n}\n\n// Detecta intenção de interesse em serviço\nconst PALAVRAS_QUENTES = ['sistema', 'agente', 'automação', 'automatizar', 'bot', 'ia', 'inteligência', 'site', 'lp', 'landing', 'fazer', 'quero', 'preciso', 'orçamento', 'valor', 'preço'];\nconst textoLower = texto.toLowerCase();\nconst ehInteresse = PALAVRAS_QUENTES.some(p => textoLower.includes(p));\n\nreturn [{\n  json: {\n    ignorar: false,\n    ig_sender_id: remetenteId,\n    mensagem_original: texto,\n    eh_interesse: ehInteresse,\n    timestamp: new Date(timestamp * 1000).toISOString(),\n    canal: 'instagram_dm'\n  }\n}];"
      },
      "id": "node-parse-ig",
      "name": "Parsear DM do Instagram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {},
          "conditions": [
            {
              "id": "cond-ignorar",
              "leftValue": "={{ $json.ignorar }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "false" }
            }
          ]
        }
      },
      "id": "node-if-ignorar",
      "name": "Deve Processar?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [760, 300]
    },
    {
