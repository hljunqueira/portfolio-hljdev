              "leftValue": "={{ $json.eh_interesse }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true" }
            }
          ]
        }
      },
      "id": "node-if-interesse",
      "name": "É Mensagem de Interesse?",
