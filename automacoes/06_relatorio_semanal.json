      "id": "node-buscar-vendas-semana",
      "name": "Supabase — Buscar Vendas Semana",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        760,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const leads = $('Supabase — Buscar Leads Semana').first().json;\nconst vendas = $('Supabase — Buscar Vendas Semana').first().json;\n\nconst totalLeads = leads.length || 0;\nconst totalVendas = vendas.length || 0;\nconst faturamento = vendas.reduce((sum, v) => sum + (parseFloat(v.valor) || 0), 0);\nconst conversao = totalLeads > 0 ? ((totalVendas / totalLeads) * 100).toFixed(1) : 0;\n\nconst mensagem = `📊 RELATÓRIO SEMANAL - HLJ DEV\n━━━━━━━━━━━━━━━━━━━━━━━\n📅 Semana: {{ $now.toFormat('dd/MM/yyyy') }}\n\n👥 Leads: ${totalLeads}\n💰 Vendas: ${totalVendas}\n💵 Faturamento: R$ ${faturamento.toFixed(2)}\n📈 Conversão: ${conversao}%\n\n━━━━━━━━━━━━━━━━━━━━━━━\n✅ Continue assim!`;\n\nreturn [{ json: { mensagem, totalLeads, totalVendas, faturamento, conversao } }];"
      },
      "id": "node-gerar-relatorio",
      "name": "Gerar Relatório",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1020,
        300
      ]
    },
